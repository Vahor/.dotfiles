#!/usr/bin/env bash

error() {
  echo "Error: $1" >&2
  exit 1
}

remote_to_web_url() {
  local remote_url=$1
  local host path rest

  case "$remote_url" in
    # git@github.com:user/repo.git
    git@*:*)
      rest=${remote_url#git@}
      host=${rest%%:*}
      path=${rest#*:}
      ;;
    # ssh://git@github.com/user/repo.git
    ssh://*)
      rest=${remote_url#ssh://}
      rest=${rest#*@}
      host=${rest%%/*}
      path=${rest#*/}
      ;;
    http://*|https://*)
      echo "${remote_url%.git}"
      return
      ;;
    *)
      echo "${remote_url%.git}"
      return
      ;;
  esac

  path=${path#/}
  path=${path%.git}
  echo "https://$host/$path"
}

open_url() {
  local url=$1

  if command -v open >/dev/null 2>&1; then
    open "$url" >/dev/null 2>&1
  elif command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$url" >/dev/null 2>&1
  else
    error "No opener found (expected open or xdg-open)."
  fi
}

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  error "Not in a git repository."
fi

remote_url=$(git config --get remote.origin.url)

if [[ -z "$remote_url" ]]; then
  error "No remote found."
fi

web_url=$(remote_to_web_url "$remote_url")

echo "Opening $web_url"
open_url "$web_url"
