#!/usr/bin/env bash

# https://github.com/ThePrimeagen/.dotfiles/blob/master/bin/.local/scripts/tmux-sessionizer

SEARCH_FOLDERS=(
    ~/dev/vahor
    # ~/dev/vahor/pedaki
    # ~/dev/helosion
    "/Users/nathan/Library/Mobile Documents/iCloud~md~obsidian/Documents"
)

selected=""

if [[ $# -eq 1 ]]; then
    selected=$1
else
    require_command fzf

    selected=$(find "${SEARCH_FOLDERS[@]}" -mindepth 1 -maxdepth 1 -type d -not -path '*/.*' 2>/dev/null | fzf)
fi

if [[ -z "$selected" ]]; then
    exit 0
fi

require_command tmux

selected_name=$(basename "$selected" | tr '. ' '__')
target_session="=$selected_name"
tmux_running=$(pgrep -x tmux 2>/dev/null)

if [[ -z "$TMUX" ]] && [[ -z "$tmux_running" ]]; then
    tmux new-session -s "$selected_name" -c "$selected"
    exit 0
fi

if ! tmux has-session -t "$target_session" 2> /dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected"
fi

tmux switch-client -t "$target_session"
